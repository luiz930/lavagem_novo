{
  "expo": {
    "name": "Wagen App",
    "slug": "wagen-mobile",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "icon": "./src/assets/icon-round.png",
    "splash": {
      "image": "./src/assets/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "androidStatusBar": {
      "backgroundColor": "#000000",
      "barStyle": "light-content"
    },
    "androidNavigationBar": {
      "backgroundColor": "#000000",
      "barStyle": "light-content"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "android": {
      "package": "com.wagen.mobile",
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/icon-round.png",
        "backgroundColor": "#000000"
      },
      "permissions": [
        "CAMERA"
      ]
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.wagen.mobile",
      "infoPlist": {
        "NSCameraUsageDescription": "O app usa a camera para registrar fotos dos atendimentos."
      }
    },
    "plugins": [
      "expo-sqlite",
      [
        "expo-camera",
        {
          "cameraPermission": "Permitir que o Wagen registre fotos dos atendimentos."
        }
      ],
      "expo-font",
      "expo-asset"
    ]
  }
}
